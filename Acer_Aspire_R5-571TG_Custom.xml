<?xml version="1.0" encoding="utf-8"?>
<FanControlConfigV2 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                    xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <!-- ============================================================ -->
  <!-- CUSTOM CONFIG for Acer Aspire R5-571TG                       -->
  <!-- Created via direct RWEverything EC read analysis             -->
  <!-- Fan speed register: 0x93 (147) - Inverted scale              -->
  <!-- Fan mode register: 0x9B (155) - 0x00 / 0xFF                  -->
  <!-- Temperature registers: 0xE2 (226) / 0xE3 (227)               -->
  <!-- ============================================================ -->
  <NotebookModel>Acer Aspire R5-571TG (Custom)</NotebookModel>
  <Author>Custom (RWEverything mapped)</Author>
  <EcPollInterval>3000</EcPollInterval>
  <ReadWriteWords>false</ReadWriteWords>
  <CriticalTemperature>90</CriticalTemperature>
  <FanConfigurations>
    <FanConfiguration>
      <!-- Register 0x93 (Row 90, Col 03) = 147 in decimal -->
      <ReadRegister>147</ReadRegister>
      <WriteRegister>147</WriteRegister>

      <!-- Acer inverted scale: 00 = Max speed, FF/CD = Min/Off -->
      <MinSpeedValue>255</MinSpeedValue>
      <MaxSpeedValue>0</MaxSpeedValue>
      <IndependentReadMinMaxValues>false</IndependentReadMinMaxValues>

      <!-- Register 0x9B (Row 90, Col 0B) = 155 in decimal for Manual Mode -->
      <ResetRequired>true</ResetRequired>
      <FanSpeedResetValue>255</FanSpeedResetValue>
      <FanDisplayName>Main Fan</FanDisplayName>

      <TemperatureThresholds>
        <TemperatureThreshold>
          <UpThreshold>45</UpThreshold>
          <DownThreshold>0</DownThreshold>
          <FanSpeed>0</FanSpeed>
        </TemperatureThreshold>
        <TemperatureThreshold>
          <UpThreshold>55</UpThreshold>
          <DownThreshold>40</DownThreshold>
          <FanSpeed>20</FanSpeed>
        </TemperatureThreshold>
        <TemperatureThreshold>
          <UpThreshold>65</UpThreshold>
          <DownThreshold>50</DownThreshold>
          <FanSpeed>40</FanSpeed>
        </TemperatureThreshold>
        <TemperatureThreshold>
          <UpThreshold>75</UpThreshold>
          <DownThreshold>60</DownThreshold>
          <FanSpeed>65</FanSpeed>
        </TemperatureThreshold>
        <TemperatureThreshold>
          <UpThreshold>85</UpThreshold>
          <DownThreshold>70</DownThreshold>
          <FanSpeed>100</FanSpeed>
        </TemperatureThreshold>
      </TemperatureThresholds>
      <FanSpeedPercentageOverrides />
    </FanConfiguration>
  </FanConfigurations>

  <RegisterWriteConfigurations>
    <RegisterWriteConfiguration>
      <!-- Mode Toggle: Register 0x9B (155). 0xFF = Auto/Default, 0x00 = Manual Override -->
      <WriteMode>Set</WriteMode>
      <WriteOccurrence>OnInitialization</WriteOccurrence>
      <Register>155</Register>
      <Value>0</Value>
    </RegisterWriteConfiguration>
    <RegisterWriteConfiguration>
      <WriteMode>Set</WriteMode>
      <WriteOccurrence>OnExit</WriteOccurrence>
      <Register>155</Register>
      <Value>255</Value>
    </RegisterWriteConfiguration>
  </RegisterWriteConfigurations>
</FanControlConfigV2>
